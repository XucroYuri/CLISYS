{
  "name": "clisys",
  "version": "0.1.0",
  "description": "CLISYS - Multi-CLI Intelligent Collaboration System | Meta-CLI evolving into Agentic Execution Fabric",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clisys": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "bun run --watch src/cli/index.ts",
    "build": "bun build ./src/cli/index.ts --outdir ./dist --target node",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "ai",
    "orchestration",
    "multi-agent",
    "claude",
    "codex",
    "gemini",
    "meta-cli",
    "agentic"
  ],
  "author": "XucroYuri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XucroYuri/CLISYS.git"
  },
  "bugs": {
    "url": "https://github.com/XucroYuri/CLISYS/issues"
  },
  "homepage": "https://github.com/XucroYuri/CLISYS#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "clipanion": "^4.0.0-rc.4",
    "typanion": "^3.14.0",
    "@iarna/toml": "^2.2.5",
    "drizzle-orm": "^0.30.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.11.0",
    "drizzle-kit": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
